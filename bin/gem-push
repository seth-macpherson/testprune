#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"
CONFIG="$REPO_ROOT/.push-gem-config"

# ── helpers ───────────────────────────────────────────────────────────────────

die()  { echo "gem-push: $*" >&2; exit 1; }
info() { echo "gem-push: $*"; }

require_op() {
  command -v op &>/dev/null || \
    die "1Password CLI (op) not found. Install: https://developer.1password.com/docs/cli/"
}

# ── first-run: record 1Password item name ─────────────────────────────────────

setup_item() {
  echo ""
  echo "gem-push: first run — enter the name of your 1Password item that holds the RubyGems OTP."
  echo "  (e.g. 'rubygems.org')"
  echo ""
  read -rp "  Item name: " item_name
  [[ -n "$item_name" ]] || die "Item name cannot be blank."

  echo ""
  info "Verifying OTP for '$item_name'..."
  op item get "$item_name" --otp &>/dev/null || \
    die "Could not fetch OTP for '$item_name'. Check the item name and that it has a one-time password field."

  {
    echo "# gem-push config — git-ignored, do not commit"
    echo "item_name=$item_name"
  } > "$CONFIG"

  info "Config saved to .push-gem-config"
  echo ""
}

# ── main ──────────────────────────────────────────────────────────────────────

require_op

[[ -f "$CONFIG" ]] || setup_item

item_name=$(grep '^item_name=' "$CONFIG" | cut -d= -f2-)

cd "$REPO_ROOT"

# Build — suppress rdoc noise, show only the success line
info "Building gem..."
build_out=$(rv run gem build testprune.gemspec 2>&1) || die "gem build failed:\n$build_out"
echo "$build_out" | grep -E 'Successfully built|Version:|File:'

gem_file=$(ls -t "$REPO_ROOT"/testprune-*.gem 2>/dev/null | head -1)
[[ -n "$gem_file" ]] || die "No .gem file found after build."
version=$(basename "$gem_file" .gem | sed 's/testprune-//')

# Fetch OTP as late as possible to avoid expiry during build
info "Fetching OTP from 1Password ($item_name)..."
otp=$(op item get "$item_name" --otp)

info "Pushing testprune $version to RubyGems..."
rv run gem push "$gem_file" --otp "$otp"
